{
  "name": "wardest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:init:local": "wrangler d1 execute wardest-db --local --file=./db/schema.sql",
    "db:seed:local": "wrangler d1 execute wardest-db --local --file=./db/seed-m44.sql",
    "db:reset:local": "npm run db:init:local && npm run db:seed:local",
    "kv:seed:local": "wrangler kv bulk put --binding=GO4_LINKS --local ./seed/links.json"
  },
  "dependencies": {
    "hono": "^4.9.0",
    "uqr": "^0.1.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "typescript": "^5.7.0",
    "wrangler": "^4.111.0"
  }
}
